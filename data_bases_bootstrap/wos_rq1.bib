Editor = {Shahriar, H and Teranishi, Y and Cuzzocrea, A and Sharmin, M and Towey, D and Majumder, AKMJA and Kashiwazaki, H and Yang, JJ and Takemoto, M and Sakib, N and Banno, R and Ahamed, SI},
Title = {The Graph-Massivizer Approach Toward a European Sustainable Data Center
